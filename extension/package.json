{
  "name": "dzhambaz-extension",
  "displayName": "Джамбаз",
  "version": "0.3.1",
  "description": "Истинската пазарна цена на вашия автомобил — директно в браузъра.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv3",
    "package:chrome": "plasmo build --zip",
    "package:firefox": "plasmo build --target=firefox-mv3 --zip",
    "package:all": "npm run package:chrome && npm run package:firefox"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.13.0",
    "plasmo": "^0.90.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.0"
  },
  "manifest": {
    "host_permissions": [
      "*://www.mobile.bg/*",
      "*://www.cars.bg/*"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "dzhambaz@dobrinov.github.io",
        "strict_min_version": "109.0"
      }
    }
  }
}
